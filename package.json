{
  "name": "nonograma",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Oriental-themed Picross puzzle game",
  "homepage": "https://nonograma.alsogravity.com/",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "vite",
    "build": "vitest run src/data/puzzles.test.ts src/data/puzzles-solvability.test.ts && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:docker": "docker compose --profile tests run --rm --build e2e",
    "test:e2e:docker:all": "docker compose --profile tests run --rm --build e2e-all"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@tailwindcss/vite": "^4.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  }
}
